+// [PATCH] IVF host view: referenceFrom implementation
+void GpuIndexIVFFlat::referenceFrom(const faiss::IndexIVFFlat* index) {
+    DeviceScope scope(config_.device);
+
+    FAISS_THROW_IF_NOT_MSG(
+        !should_use_cuvs(config_),
+        "referenceFrom requires use_cuvs=false "
+        "(cuVS IVF forces interleaved layout, incompatible with host view)");
+
+    // Copy coarse quantizer (centroids) to GPU -- small: nlist * d * 4 bytes
+    GpuIndexIVF::copyFrom(index);
+
+    // Clear and recreate the IVFFlat impl
+    index_.reset();
+    if (!should_use_cuvs(config_)) {
+        baseIndex_.reset();
+    }
+
+    if (!index->is_trained) {
+        FAISS_ASSERT(!is_trained);
+        return;
+    }
+    FAISS_ASSERT(is_trained);
+
+    // Create IVFFlat with interleavedLayout=false -- critical for format compat.
+    // translateCodesToGpu_() is a no-op when !interleavedLayout_ (IVFFlat.cu:91),
+    // so CPU and GPU use identical flat [vector][dimension] byte layout.
+    setIndex_(
+        resources_.get(), d, nlist,
+        index->metric_type, index->metric_arg,
+        false,          // no residual
+        nullptr,        // no scalar quantizer
+        false,          // interleavedLayout = false (MUST match CPU format)
+        INDICES_64_BIT, // required for direct pointer reference
+        config_.memorySpace);
+    baseIndex_ = std::static_pointer_cast<IVFBase, IVFFlat>(index_);
+    updateQuantizer();
+
+    // Reference (not copy) the CPU inverted lists -- zero-copy host view
+    index_->referenceInvertedListsFrom(index->invlists);
+}
