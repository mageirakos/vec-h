+// [PATCH] IVF host view: referenceInvertedListsFrom implementation
+void IVFBase::referenceInvertedListsFrom(const InvertedLists* ivf) {
+    FAISS_THROW_IF_NOT_MSG(
+        !interleavedLayout_,
+        "referenceInvertedListsFrom requires interleavedLayout=false "
+        "(CPU and GPU data formats must match for zero-copy)");
+    FAISS_THROW_IF_NOT_MSG(
+        indicesOptions_ == INDICES_64_BIT,
+        "referenceInvertedListsFrom requires INDICES_64_BIT "
+        "(direct pointer reference for index IDs)");
+
+    auto stream = resources_->getDefaultStreamCurrentDevice();
+    idx_t nlist = ivf ? ivf->nlist : 0;
+
+    for (idx_t i = 0; i < nlist; ++i) {
+        idx_t listSize = ivf->list_size(i);
+        if (listSize == 0) continue;
+
+        // Set numVecs on DeviceIVFList shells (data stays empty, no GPU alloc)
+        deviceListData_[i]->numVecs = listSize;
+        deviceListIndices_[i]->numVecs = listSize;
+
+        // Point GPU pointer arrays at host memory.
+        // On ATS systems, the GPU can dereference these host pointers directly.
+        // setAt() copies 8 bytes (the pointer value) H2D into the pointer array.
+        deviceListDataPointers_.setAt(
+            i, (void*)ivf->get_codes(i), stream);
+        deviceListIndexPointers_.setAt(
+            i, (void*)ivf->get_ids(i), stream);
+        deviceListLengths_.setAt(i, listSize, stream);
+
+        maxListLength_ = std::max(maxListLength_, listSize);
+    }
+    // NOTE: Do NOT call updateDeviceListInfo_() here. That method reads
+    // deviceListData_[i]->data.data() which is empty/null for host-view lists.
+}
