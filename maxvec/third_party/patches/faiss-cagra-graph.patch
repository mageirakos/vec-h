+        const uint32_t* knn_graph_uint32,
+        const float* dataset,
+        idx_t n,
+        int graph_degree) {
+    FAISS_ASSERT(knn_graph_uint32);
+    FAISS_ASSERT(dataset);
+    numeric_type_ = NumericType::Float32;
+
+    DeviceScope scope(config_.device);
+
+    // Set base GpuIndex fields (normally done by GpuIndex::copyFrom)
+    this->ntotal = n;
+    this->is_trained = true;
+
+    index_ = std::make_shared<CuvsCagra<float>>(
+            this->resources_.get(),
+            this->d,
+            n,
+            graph_degree,
+            dataset,
+            knn_graph_uint32,
+            this->metric_type,
+            this->metric_arg,
+            INDICES_64_BIT);
+}
